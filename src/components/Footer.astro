---
// Footer component with premium design and red theme
interface SocialLink {
    name: string;
    href: string;
    icon: string;
}

const socialLinks: SocialLink[] = [
    {
        name: "GitHub",
        href: "https://github.com/Kevingedev",
        icon: "github",
    },
    {
        name: "LinkedIn",
        href: "https://www.linkedin.com/in/kevinruizgutierrez/",
        icon: "linkedin",
    },
    {
        name: "Instagram",
        href: "https://www.instagram.com/imkevinrz",
        icon: "instagram",
    },
];

const currentYear = new Date().getFullYear();
---

<footer class="relative bg-[#050000] border-t border-red-500/10">
    <div
        class="max-w-[1200px] mx-auto px-6 py-8 md:py-10 flex flex-col md:flex-row items-center justify-between gap-6"
    >
        <!-- Brand Section (Left) -->
        <div class="flex flex-col items-center md:items-start gap-2">
            <a
                href="/"
                class="text-xl font-bold text-white hover:text-red-500 transition-colors duration-300"
            >
                Kevin<span class="text-red-500"> Ruiz</span>
            </a>
            <p class="text-sm text-slate-400 text-center md:text-left">
                © {currentYear} Kevin Ruiz. All rights reserved.
            </p>
        </div>

        <!-- Social Icons (Right) -->
        <div class="flex items-center gap-4">
            {
                socialLinks.map(({ name, href, icon }) => (
                    <a
                        href={href}
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label={name}
                        class="social-icon-link group relative flex items-center justify-center w-10 h-10 rounded-full bg-transparent border border-transparent hover:border-red-500/30 transition-all duration-300"
                    >
                        {icon === "github" && (
                            <svg
                                class="w-5 h-5 text-slate-400 group-hover:text-red-500 transition-colors duration-300"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                            </svg>
                        )}
                        {icon === "linkedin" && (
                            <svg
                                class="w-5 h-5 text-slate-400 group-hover:text-red-500 transition-colors duration-300"
                                fill="currentColor"
                                viewBox="0 0 24 24"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                            </svg>
                        )}
                        {icon === "instagram" && (
                        <svg 
                            class="w-5 h-5 text-slate-400 group-hover:text-red-500 transition-colors duration-300" 
                            fill="currentColor" 
                            viewBox="0 0 24 24" 
                            xmlns="http://www.w3.org/2000/svg"
                        >
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.332 3.608 1.308.975.975 1.246 2.242 1.308 3.607.058 1.266.07 1.646.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.332 2.633-1.308 3.608-.975.975-2.242 1.246-3.607 1.308-1.266.058-1.646.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.332-3.608-1.308-.975-.975-1.246-2.242-1.308-3.607C2.175 15.584 2.163 15.204 2.163 12s.012-3.584.07-4.85c.062-1.366.332-2.633 1.308-3.608.975-.975 2.242-1.246 3.607-1.308 1.266-.058 1.646-.07 4.85-.07M12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.072 7.052.014 8.333 0 8.741 0 12s.014 3.667.072 4.947c.2 4.353 2.612 6.777 6.973 6.977 1.28.057 1.688.072 4.947.072s3.667-.015 4.947-.072c4.351-.2 6.777-2.612 6.977-6.977.058-1.28.072-1.688.072-4.947s-.015-3.667-.072-4.947c-.2-4.349-2.612-6.778-6.977-6.977C15.667.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" />
                        </svg>
                        )}

                        <!-- Hover glow effect -->
                        <span class="absolute inset-0 rounded-full bg-red-500/0 group-hover:bg-red-500/5 transition-colors duration-300" />
                    </a>
                ))
            }
        </div>
    </div>

    <!-- Subtle bottom glow -->
    <div
        class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[400px] h-[100px] bg-gradient-to-t from-red-500/5 to-transparent blur-3xl pointer-events-none"
    >
    </div>
</footer>

<style>
    .social-icon-link {
        transition:
            transform 0.3s ease-out,
            border-color 0.3s ease-out,
            background-color 0.3s ease-out;
    }

    .social-icon-link:hover {
        transform: translateY(-2px);
    }

    .social-icon-link:active {
        transform: translateY(0) scale(0.95);
    }
</style>
