---
interface SocialNetworksProps {
  name: string;
  link: string;
  icon: string;
}

const socialNetworks: SocialNetworksProps[] = [
  { name: 'GitHub', link: 'https://github.com/Kevingedev', icon: 'devicon-github-original' },
  { name: 'LinkedIn', link: 'https://www.linkedin.com/in/kevinruizgutierrez/', icon: 'devicon-linkedin-plain' },
  { name: 'Email', link: 'https://mail.google.com/mail/u/0/?view=cm&fs=1&to=kevingerardoruiz.2001@gmail.com', icon: 'devicon-google-plain' },
];
---

<div class="social-networks-container flex justify-center items-center gap-4 py-4">
  {socialNetworks.map(({ name, link, icon }) => (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="social-link group relative flex items-center justify-center w-14 h-14 rounded-2xl bg-[rgba(10,1,1,0.6)] border border-red-500/20 backdrop-blur-md"
      aria-label={name}
    >
      <!-- Glow effect on hover -->
      <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-red-500/0 to-red-500/0 group-hover:from-red-500/10 group-hover:to-red-600/5 transition-all duration-500 ease-out pointer-events-none"></div>

      <!-- Icon -->
      <i class={`${icon} social-icon text-2xl text-slate-300 relative z-10`}></i>

      <!-- Tooltip -->
      <span class="tooltip absolute -bottom-10 left-1/2 px-3 py-1.5 bg-[rgba(10,1,1,0.9)] border border-red-500/30 rounded-lg text-xs font-medium text-slate-300 whitespace-nowrap backdrop-blur-sm pointer-events-none">
        {name}
        <!-- Tooltip arrow -->
        <span class="absolute -top-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-[rgba(10,1,1,0.9)] border-l border-t border-red-500/30 rotate-45"></span>
      </span>

      <!-- Ripple effect container -->
      <span class="ripple-container absolute inset-0 rounded-2xl overflow-hidden pointer-events-none"></span>
    </a>
  ))}
</div>

<style>
  .social-link {
    transition: background-color 0.5s ease-out, border-color 0.5s ease-out, box-shadow 0.5s ease-out, transform 0.3s ease-out;
  }

  .social-link:hover {
    background-color: rgba(69, 10, 10, 0.4);
    border-color: rgba(239, 68, 68, 0.5);
    box-shadow: 0 10px 40px -10px rgba(239, 68, 68, 0.4);
    transform: scale(1.1) translateY(-4px);
  }

  .social-link:active {
    transform: scale(0.95);
  }

  .social-icon {
    transition: color 0.5s ease-out, transform 0.3s ease-out;
  }

  .social-link:hover .social-icon {
    color: rgb(239, 68, 68);
    transform: scale(1.1);
  }



  /* Tooltip styles */
  .tooltip {
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(8px);
    transition: opacity 0.3s ease-out, visibility 0.3s ease-out, transform 0.3s ease-out;
  }

  .social-link:hover .tooltip {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* Ripple effect */
  .ripple-container .ripple {
    position: absolute;
    border-radius: 50%;
    background: rgba(239, 68, 68, 0.3);
    transform: scale(0);
    animation: ripple-animation 0.6s ease-out;
  }

  @keyframes ripple-animation {
    to {
      transform: scale(4);
      opacity: 0;
    }
  }

  /* Responsive adjustments */
  @media (max-width: 640px) {
    .social-link {
      width: 3rem;
      height: 3rem;
    }

    .social-icon {
      font-size: 1.25rem;
    }

    .tooltip {
      display: none;
    }
  }
</style>

<script>
  // Add ripple effect on click
  document.querySelectorAll('.social-link').forEach((link) => {
    link.addEventListener('click', function (e) {
      const rippleContainer = this.querySelector('.ripple-container');
      if (!rippleContainer) return;

      const rect = this.getBoundingClientRect();
      const x = (e as MouseEvent).clientX - rect.left;
      const y = (e as MouseEvent).clientY - rect.top;

      const ripple = document.createElement('span');
      ripple.className = 'ripple';
      ripple.style.left = `${x}px`;
      ripple.style.top = `${y}px`;

      rippleContainer.appendChild(ripple);

      setTimeout(() => {
        ripple.remove();
      }, 600);
    });
  });
</script>
