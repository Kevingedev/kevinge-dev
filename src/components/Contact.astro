---
// Contact Form component with premium design and red theme
---

<section
    id="contact"
    class="relative py-20 md:py-28 px-6 bg-[#050000] overflow-hidden"
>
    <!-- Background Glow Effect -->
    <div class="contact-glow"></div>

    <div class="relative z-10 max-w-[1200px] mx-auto">
        <!-- Section Header -->
        <div class="text-center mb-12 md:mb-16">
            <span
                class="inline-block px-4 py-1.5 mb-6 text-xs font-semibold tracking-wider uppercase text-red-400 bg-red-500/10 border border-red-500/20 rounded-full"
            >
                Contacto
            </span>
            <h2
                class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight"
            >
                ¿Do you have a project in mind?
                <span class="text-red-500 block sm:inline">Let's talk.</span>
            </h2>
            <p class="text-lg text-slate-400 max-w-[600px] mx-auto">
                I am open to freelance work and collaborative projects. Feel
                free to reach out to discuss opportunities—I am excited to work
                with you.
            </p>
        </div>

        <!-- Contact Card -->
        <div class="max-w-[700px] mx-auto">
            <div
                class="contact-card relative p-8 md:p-10 bg-[rgba(10,1,1,0.6)] border border-red-500/10 rounded-[24px] backdrop-blur-sm"
            >
                <!-- Card glow effect -->
                <div
                    class="absolute inset-0 rounded-[24px] bg-gradient-to-br from-red-500/5 via-transparent to-red-500/5 pointer-events-none"
                >
                </div>

                <!-- Form -->
                <form
                    id="contact-form"
                    class="relative z-10 flex flex-col gap-6"
                >
                    <!-- Name Field -->
                    <div class="form-group">
                        <label
                            for="name"
                            class="block mb-2 text-sm font-medium text-slate-300"
                        >
                            Name
                        </label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            placeholder="Your Name"
                            class="form-input w-full px-5 py-4 bg-[#0a0000] border border-red-500/20 rounded-2xl text-white placeholder-slate-500 outline-none transition-all duration-300 focus:border-red-500/60 focus:shadow-[0_0_20px_-5px_rgba(239,68,68,0.3)]"
                        />
                    </div>

                    <!-- Email Field -->
                    <div class="form-group">
                        <label
                            for="email"
                            class="block mb-2 text-sm font-medium text-slate-300"
                        >
                            Email
                        </label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="your@email.com"
                            class="form-input w-full px-5 py-4 bg-[#0a0000] border border-red-500/20 rounded-2xl text-white placeholder-slate-500 outline-none transition-all duration-300 focus:border-red-500/60 focus:shadow-[0_0_20px_-5px_rgba(239,68,68,0.3)]"
                        />
                    </div>

                    <!-- Message Field -->
                    <div class="form-group">
                        <label
                            for="message"
                            class="block mb-2 text-sm font-medium text-slate-300"
                        >
                            Message
                        </label>
                        <textarea
                            id="message"
                            name="message"
                            required
                            rows="5"
                            placeholder="Let me know how I can help you!"
                            class="form-input w-full px-5 py-4 bg-[#0a0000] border border-red-500/20 rounded-2xl text-white placeholder-slate-500 outline-none transition-all duration-300 resize-none focus:border-red-500/60 focus:shadow-[0_0_20px_-5px_rgba(239,68,68,0.3)]"
                        ></textarea>
                    </div>

                    <!-- Submit Button -->
                    <button
                        type="submit"
                        id="submit-button"
                        class="submit-btn group relative flex items-center justify-center gap-3 w-full px-8 py-4 mt-2 bg-gradient-to-br from-red-500 to-red-600 text-white font-semibold text-base rounded-full overflow-hidden transition-all duration-700 hover:shadow-[0_10px_40px_-10px_rgba(239,68,68,0.5)]"
                    >
                        <!-- Button shine effect -->
                        <span
                            class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -translate-x-full group-hover:translate-x-full transition-transform duration-700 ease-out"
                        ></span>

                        <span
                            class="btn-content relative z-10 flex items-center gap-2"
                        >
                            <span class="btn-text">Send Message</span>
                        </span>
                    </button>

                    <!-- Feedback Message -->
                    <div
                        id="form-feedback"
                        class="hidden text-center text-sm font-medium py-2 rounded-xl"
                    >
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

<style>
    /* Background glow */
    .contact-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 500px;
        height: 500px;
        background: radial-gradient(
            circle,
            rgba(69, 10, 10, 0.3) 0%,
            rgba(69, 10, 10, 0.1) 40%,
            transparent 70%
        );
        filter: blur(100px);
        -webkit-filter: blur(100px);
        z-index: 0;
        pointer-events: none;
    }

    @media (max-width: 640px) {
        .contact-glow {
            width: 300px;
            height: 300px;
        }
    }

    /* Contact card hover effect */
    .contact-card {
        transition:
            border-color 0.5s ease,
            box-shadow 0.5s ease,
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .contact-card:hover {
        border-color: rgba(239, 68, 68, 0.2);
        box-shadow:
            0 20px 60px -20px rgba(0, 0, 0, 0.5),
            0 0 40px -20px rgba(239, 68, 68, 0.2);
    }

    /* Form input styles */
    .form-input {
        font-size: 1rem;
    }

    .form-input::placeholder {
        transition: color 0.3s ease;
    }

    .form-input:focus::placeholder {
        color: rgba(239, 68, 68, 0.4);
    }

    /* Submit button styles */
    .submit-btn {
        box-shadow: 0 4px 20px -4px rgba(239, 68, 68, 0.4);
    }

    .submit-btn:hover {
        transform: translateY(-2px);
    }

    .submit-btn:active {
        transform: translateY(0) scale(0.8);
    }

    /* Form group animation */
    .form-group {
        opacity: 0;
        animation: fade-in-up 0.6s ease-out forwards;
    }

    .form-group:nth-child(1) {
        animation-delay: 0.1s;
    }

    .form-group:nth-child(2) {
        animation-delay: 0.2s;
    }

    .form-group:nth-child(3) {
        animation-delay: 0.3s;
    }

    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Feedback Alert Glassmorphism Styles */
    #form-feedback {
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1.25rem 1.5rem;
        border-radius: 1.25rem;
        margin-top: 1.5rem;
        transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        animation: slide-up 0.4s ease-out forwards;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 500;
        z-index: 20;
    }

    #form-feedback.success {
        background: rgba(34, 197, 94, 0.1);
        border-color: rgba(34, 197, 94, 0.3);
        color: #4ade80;
        box-shadow: 0 10px 40px -10px rgba(34, 197, 94, 0.3);
    }

    #form-feedback.error {
        background: rgba(239, 68, 68, 0.1);
        border-color: rgba(239, 68, 68, 0.3);
        color: #f87171;
        box-shadow: 0 10px 40px -10px rgba(239, 68, 68, 0.3);
    }

    @keyframes slide-up {
        from {
            opacity: 0;
            transform: translateY(15px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<script is:inline>
    const contactForm = document.getElementById("contact-form");
    const feedbackEl = document.getElementById("form-feedback");
    const submitBtn = document.getElementById("submit-button");
    const btnText = submitBtn?.querySelector(".btn-text");

    if (contactForm) {
        contactForm.addEventListener("submit", async (e) => {
            e.preventDefault();

            // Initial UI state
            if (feedbackEl) {
                feedbackEl.classList.add("hidden");
                feedbackEl.textContent = "";
            }
            if (btnText) btnText.textContent = "Sending...";
            if (submitBtn) submitBtn.disabled = true;

            try {
                const formData = new FormData(contactForm);
                const data = Object.fromEntries(formData.entries());

                const response = await fetch("/api/contact", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                    },
                    body: JSON.stringify(data),
                });

                let result;
                const contentType = response.headers.get("content-type");
                if (contentType && contentType.includes("application/json")) {
                    result = await response.json();
                } else {
                    const text = await response.text();
                    throw new Error(
                        `Invalid response format: ${text.substring(0, 100)}`,
                    );
                }

                if (response.ok) {
                    showFeedback(result.message, "success");
                    contactForm.reset();
                } else {
                    showFeedback(
                        result.message || "Something went wrong.",
                        "error",
                    );
                }
            } catch (error) {
                console.error("Submission error:", error);
                showFeedback("Error connecting to the server.", "error");
            } finally {
                if (btnText) btnText.textContent = "Send Message";
                if (submitBtn) submitBtn.disabled = false;
            }
        });
    }

    function showFeedback(message, type) {
        if (!feedbackEl) return;

        feedbackEl.textContent = message;
        feedbackEl.classList.remove("hidden", "success", "error");
        feedbackEl.classList.add(type);

        // Auto-hide after 6 seconds with a fade out
        setTimeout(() => {
            feedbackEl.classList.add("hidden");
        }, 6000);
    }
</script>
