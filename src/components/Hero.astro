---
// Hero Section component with premium design and red theme
import SocialNetworks from "./SocialNetworks.astro";
import { Image } from "astro:assets";
import AvatarImage from "../assets/img/Avatar-Web-Me.png";
import ExperienceModal from "./ExperienceModal.astro";
import type { ImageMetadata } from "astro";

interface Avatar {
    src: ImageMetadata;
    alt: string;
    fallbackBg?: string;
}

const avatar: Avatar = {
    src: AvatarImage,
    alt: "Kevin",
    fallbackBg: "#fca5a5",
};
---

<section
    id="about"
    class="relative min-h-[80vh] md:min-h-[70vh] flex flex-col items-center justify-center py-8 px-6 overflow-hidden bg-[var(--bg-primary)]"
>
    <!-- Background Glow Effect -->
    <div class="hero-glow"></div>

    <div
        class="relative z-10 max-w-[1200px] w-full flex flex-col items-center text-center gap-8 animate-fade-in-up"
    >
        <!-- Avatar -->
        <div class="avatar-container animate-fade-in-up animation-delay-200">
            <!-- Rotating gradient ring -->
            <div class="avatar-ring"></div>
            <!-- Glow effect -->
            <div class="avatar-glow"></div>
            <!-- Avatar wrapper -->
            <div class="avatar-wrapper">
                <Image src={avatar.src} alt={avatar.alt} class="avatar-image" />
            </div>
        </div>
        <!-- Availability Badge -->
        <div
            class="inline-flex items-center gap-3 px-5 py-2 sm:px-4 sm:py-1.5 bg-[var(--bg-accent)] border border-red-500/30 rounded-full backdrop-blur-sm transition-all duration-300 hover:border-red-500/50 hover:bg-[var(--bg-primary)]"
        >
            <span
                class="status-dot w-2 h-2 bg-red-500 rounded-full shadow-[0_0_8px_rgba(239,68,68,0.8),0_0_16px_rgba(239,68,68,0.4)]"
            ></span>
            <span
                class="text-xs sm:text-[0.7rem] font-semibold tracking-wider uppercase text-[var(--text-muted)]"
                >AVAILABLE FOR WORK</span
            >
        </div>

        <!-- Main Heading -->
        <h1
            class="hero-title md:text-6xl sm:text-4xl text-6xl font-extrabold leading-[1.1] text-[var(--text-primary)] m-0 tracking-tight animate-fade-in-up animation-delay-200"
        >
            Building digital
            <span class="text-red-500 block sm:inline">experiences.</span>
        </h1>

        <!-- Subtitle -->
        <p
            class="text-xl md:text-lg sm:text-base text-[0.95rem] 2xl:text-[1.375rem] font-normal leading-relaxed text-[var(--text-secondary)] max-w-[700px] md:max-w-[600px] sm:max-w-full 2xl:max-w-[800px] m-0 animate-fade-in-up animation-delay-400"
        >
            I’m <span class="text-red-500 font-semibold">Kevin</span>, a
            Full-Stack Developer with <span
                class="experience-trigger link-pulse text-red-500 font-semibold cursor-pointer relative inline-block transition-all duration-300 hover:text-red-400 "
                data-open-experience
            >
                + three years of experience
                <span
                    class="absolute bottom-0 left-0 w-full h-[1px] bg-red-500/30 transform scale-x-0 transition-transform duration-300 origin-left hover:scale-x-100"
                ></span>
            </span>, passionate about creating innovative solutions and bringing
            ideas to life through code.
        </p>

        <!-- Social Networks -->
        <SocialNetworks />

        <!-- CTA Buttons -->
        <div
            class="flex gap-6 sm:gap-4 items-center flex-wrap justify-center animate-fade-in-up animation-delay-600 sm:w-full"
        >
            <a
                href="#projects"
                class="btn-primary group relative flex items-center justify-between px-8 py-4 sm:px-6 sm:py-3.5 sm:w-full sm:max-w-[170px] rounded-full font-semibold text-base sm:text-[0.95rem] text-white bg-gradient-to-br from-red-500 to-red-600 no-underline overflow-hidden"
            >
                <span class="relative z-10">See My Work</span>
                <svg
                    class="arrow-icon relative z-10"
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M12 5v14"></path>
                    <path d="m19 12-7 7-7-7"></path>
                </svg>
            </a>

            <a
                href="#contact"
                class="btn-secondary group relative inline-flex items-center justify-center px-8 py-4 sm:px-6 sm:py-3.5 sm:w-full sm:max-w-[170px] bg-transparent text-[var(--text-primary)] no-underline font-semibold text-base sm:text-[0.95rem] rounded-full overflow-hidden"
            >
                <span class="relative z-10">Contact Me</span>
            </a>
        </div>
    </div>

    <!-- Experience Modal -->
    <ExperienceModal />
</section>

<style>
    /* Glow effect */
    .hero-glow {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 600px;
        height: 600px;
        background: radial-gradient(
            circle,
            var(--hero-glow) 0%,
            transparent 70%
        );
        filter: blur(120px);
        -webkit-filter: blur(120px);
        z-index: 0;
        animation: glow-pulse 4s ease-in-out infinite;
    }

    @media (max-width: 1024px) {
        .hero-glow {
            width: 500px;
            height: 500px;
        }
    }

    @media (max-width: 640px) {
        .hero-glow {
            width: 400px;
            height: 400px;
        }
    }

    @media (max-width: 480px) {
        .hero-glow {
            width: 300px;
            height: 300px;
        }
    }

    @media (min-width: 1536px) {
        .hero-title {
            font-size: 5.5rem;
        }
    }

    @keyframes glow-pulse {
        0%,
        100% {
            opacity: 0.6;
            transform: translate(-50%, -50%) scale(1);
        }
        50% {
            opacity: 0.8;
            transform: translate(-50%, -50%) scale(1.1);
        }
    }

    /* Premium Avatar Styles */
    .avatar-container {
        position: relative;
        width: 160px;
        height: 160px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
    }

    @media (max-width: 1024px) {
        .avatar-container {
            width: 140px;
            height: 140px;
        }
    }

    @media (max-width: 640px) {
        .avatar-container {
            width: 120px;
            height: 120px;
        }
    }

    @media (max-width: 480px) {
        .avatar-container {
            width: 100px;
            height: 100px;
        }
    }

    @media (min-width: 1536px) {
        .avatar-container {
            width: 180px;
            height: 180px;
        }
    }

    /* Rotating gradient ring */
    .avatar-ring {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        padding: 3px;
        background: conic-gradient(
            from 0deg,
            #ef4444,
            #dc2626,
            #b91c1c,
            #991b1b,
            #7f1d1d,
            #991b1b,
            #b91c1c,
            #dc2626,
            #ef4444
        );
        -webkit-mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        mask:
            linear-gradient(#fff 0 0) content-box,
            linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        animation: rotate-ring 8s linear infinite;
        opacity: 0.8;
        transition:
            opacity 0.5s ease,
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .avatar-container:hover .avatar-ring {
        opacity: 1;
        animation-duration: 3s;
    }

    @keyframes rotate-ring {
        from {
            transform: rotate(0deg);
        }
        to {
            transform: rotate(360deg);
        }
    }

    /* Glow effect behind avatar */
    .avatar-glow {
        position: absolute;
        inset: -10px;
        border-radius: 50%;
        background: radial-gradient(
            circle,
            rgba(239, 68, 68, 0.4) 0%,
            rgba(239, 68, 68, 0.2) 40%,
            transparent 70%
        );
        filter: blur(15px);
        -webkit-filter: blur(15px);
        animation: avatar-glow-pulse 3s ease-in-out infinite;
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .avatar-container:hover .avatar-glow {
        inset: -20px;
        filter: blur(20px);
        -webkit-filter: blur(20px);
        background: radial-gradient(
            circle,
            rgba(239, 68, 68, 0.6) 0%,
            rgba(239, 68, 68, 0.3) 40%,
            transparent 70%
        );
    }

    @keyframes avatar-glow-pulse {
        0%,
        100% {
            opacity: 0.7;
            transform: scale(1);
        }
        50% {
            opacity: 1;
            transform: scale(1.05);
        }
    }

    /* Avatar wrapper */
    .avatar-wrapper {
        position: relative;
        width: calc(100% - 12px);
        height: calc(100% - 12px);
        border-radius: 50%;
        overflow: hidden;
        background: var(--avatar-bg);
        transition:
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.5s ease;
        box-shadow:
            0 4px 20px -4px rgba(0, 0, 0, 0.5),
            inset 0 0 20px rgba(239, 68, 68, 0.1);
    }

    .avatar-container:hover .avatar-wrapper {
        transform: scale(1.03);
        box-shadow:
            0 8px 30px -4px rgba(0, 0, 0, 0.6),
            inset 0 0 30px rgba(239, 68, 68, 0.2);
    }

    /* Avatar image */
    .avatar-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
        transition:
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            filter 0.5s ease;
        filter: brightness(0.95) contrast(1.05);
    }

    .avatar-container:hover .avatar-image {
        transform: scale(1.08);
        filter: brightness(1) contrast(1.1);
    }

    /* Active/click state */
    .avatar-container:active .avatar-wrapper {
        transform: scale(0.98);
    }

    .avatar-container:active .avatar-image {
        transform: scale(1.02);
    }

    /* Status dot pulse animation */
    .status-dot {
        animation: pulse-dot 2s ease-in-out infinite;
    }

    /* Status dot pulse animation */
    .link-pulse {
        animation: link-pulse 2s ease-in-out infinite;
    }

    @keyframes pulse-dot {
        0%,
        100% {
            opacity: 1;
            transform: scale(1);
            box-shadow:
                0 0 8px rgba(239, 68, 68, 0.8),
                0 0 16px rgba(239, 68, 68, 0.4);
        }
        50% {
            opacity: 0.7;
            transform: scale(1.2);
            box-shadow:
                0 0 12px rgba(239, 68, 68, 1),
                0 0 24px rgba(239, 68, 68, 0.6);
        }
    }

    @keyframes link-pulse {
        0%,
        100% {
            opacity: 1;
            transform: scale(1);
        }
        50% {
            opacity: 0.7;
            transform: scale(1.02);
        }
    }

    /* Fade in up animation */
    .animate-fade-in-up {
        animation: fade-in-up 0.8s ease-out forwards;
        opacity: 0;
    }

    .animation-delay-200 {
        animation-delay: 0.2s;
    }

    .animation-delay-400 {
        animation-delay: 0.4s;
    }

    .animation-delay-600 {
        animation-delay: 0.6s;
    }

    @keyframes fade-in-up {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Primary Button Styles */
    .btn-primary {
        box-shadow: 0 4px 20px -4px rgba(239, 68, 68, 0.4);
        transition:
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            background 0.5s ease-out;
    }

    .btn-primary::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom right,
            rgba(255, 255, 255, 0.15),
            transparent 50%
        );
        opacity: 0;
        transition: opacity 0.5s ease-out;
    }

    .btn-primary::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom right, #dc2626, #b91c1c);
        opacity: 0;
        transition: opacity 0.5s ease-out;
        z-index: 0;
    }

    .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow:
            0 12px 35px -8px rgba(239, 68, 68, 0.5),
            0 0 20px -4px rgba(239, 68, 68, 0.3);
    }

    .btn-primary:hover::before {
        opacity: 1;
    }

    .btn-primary:hover::after {
        opacity: 1;
    }

    .btn-primary:active {
        transform: translateY(0);
        box-shadow: 0 4px 15px -4px rgba(239, 68, 68, 0.4);
    }

    .btn-primary .arrow-icon {
        transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .btn-primary:hover .arrow-icon {
        transform: translateY(3px);
    }

    /* Secondary Button Styles */
    .btn-secondary {
        border: 2px solid rgba(239, 68, 68, 0.4);
        transition:
            transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            box-shadow 0.5s cubic-bezier(0.4, 0, 0.2, 1),
            border-color 0.5s ease-out,
            color 0.5s ease-out,
            background-color 0.5s ease-out;
    }

    .btn-secondary::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(
            circle at center,
            rgba(239, 68, 68, 0.1),
            transparent 70%
        );
        opacity: 0;
        transition: opacity 0.5s ease-out;
    }

    .btn-secondary:hover {
        transform: translateY(-3px);
        border-color: rgba(239, 68, 68, 0.7);
        color: #f87171;
        background-color: rgba(239, 68, 68, 0.05);
        box-shadow:
            0 8px 30px -10px rgba(239, 68, 68, 0.3),
            inset 0 0 20px -10px rgba(239, 68, 68, 0.2);
    }

    .btn-secondary:hover::before {
        opacity: 1;
    }

    .btn-secondary:active {
        transform: translateY(0);
        box-shadow: none;
    }

    /* Experience Trigger Animation */
    .experience-trigger {
        position: relative;
    }

    .experience-trigger::after {
        content: "";
        position: absolute;
        bottom: 2px;
        left: 0;
        width: 100%;
        height: 1px;
        background: currentColor;
        transform: scale-x(0);
        transform-origin: right;
        transition: transform 0.4s cubic-bezier(0.19, 1, 0.22, 1);
    }

    .experience-trigger:hover::after {
        transform: scale-x(1);
        transform-origin: left;
    }
</style>
