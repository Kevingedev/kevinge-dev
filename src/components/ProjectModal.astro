---
// ProjectModal.astro
// Premium Glassmorphism Modal for Project Details
import type { ImageMetadata } from "astro";

interface Project {
    id: number;
    title: string;
    description: string;
    image: ImageMetadata;
    imageBg: string;
    technologies: string[];
    link: string;
    github?: string;
}

interface Props {
    project: Project;
}

const { project } = Astro.props;
const modalId = `modal-project-${project.id}`;
---

<div id={modalId} class="project-modal-backdrop hidden">
    <div class="modal-container">
        <div class="modal-glass"></div>

        <!-- Header -->
        <div class="modal-header">
            <h2 class="text-3xl font-bold text-[var(--text-primary)] m-0">
                Project <span class="text-red-500">{project.title}</span>
            </h2>
            <button
                class="close-project-modal close-btn"
                aria-label="Close modal"
                data-close-id={modalId}
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                >
                    <path d="M18 6L6 18M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- Content -->
        <div class="modal-content custom-scrollbar">
            <!-- Project Image/Preview -->
            <div class="project-preview-container mb-8">
                <img
                    src={project.image.src}
                    alt={project.title}
                    class="project-preview-image"
                />
                <div class="image-overlay"></div>
            </div>

            <!-- Project Info -->
            <div class="project-details">
                <div class="detail-section mb-6">
                    <h4
                        class="text-red-500 font-semibold text-sm uppercase tracking-wider mb-2"
                    >
                        About the Project
                    </h4>
                    <p class="text-[var(--text-secondary)] leading-relaxed">
                        {project.description}
                    </p>
                </div>

                <div class="detail-section mb-8">
                    <h4
                        class="text-red-500 font-semibold text-sm uppercase tracking-wider mb-3"
                    >
                        Technologies Used
                    </h4>
                    <div class="flex flex-wrap gap-2">
                        {
                            project.technologies.map((tech) => (
                                <span class="tech-badge">{tech}</span>
                            ))
                        }
                    </div>
                </div>

                <!-- Footer / Links -->
                <div
                    class="modal-footer pt-6 border-t border-red-500/10 flex flex-wrap gap-4"
                >
                    {
                        project.link && (
                            <a
                                href={project.link}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn-modal-primary"
                            >
                                <span>Live Demo</span>
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                                    <polyline points="15 3 21 3 21 9" />
                                    <line x1="10" y1="14" x2="21" y2="3" />
                                </svg>
                            </a>
                        )
                    }
                    {
                        project.github && (
                            <a
                                href={project.github}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="btn-modal-secondary"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                >
                                    <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22" />
                                </svg>
                                <span>GitHub Repo</span>
                            </a>
                        )
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    /* Backdrop */
    .project-modal-backdrop {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg-primary);
        opacity: 0.85;
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 20px;
        opacity: 0;
        visibility: hidden;
        transition:
            opacity 0.4s ease-in-out,
            visibility 0.4s ease-in-out;
    }

    .project-modal-backdrop.active {
        opacity: 1;
        visibility: visible;
    }

    /* Container */
    .modal-container {
        position: relative;
        width: 100%;
        max-width: 700px;
        max-height: 90vh;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 28px;
        box-shadow:
            0 25px 50px -12px rgba(0, 0, 0, 0.7),
            0 0 40px rgba(239, 68, 68, 0.15);
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transform: scale(0.9) translateY(30px);
        transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

    .project-modal-backdrop.active .modal-container {
        transform: scale(1) translateY(0);
    }

    /* Glass Effect */
    .modal-glass {
        position: absolute;
        inset: 0;
        background: radial-gradient(
            circle at top center,
            rgba(239, 68, 68, 0.08) 0%,
            transparent 70%
        );
        pointer-events: none;
    }

    /* Header */
    .modal-header {
        position: relative;
        padding: 30px 40px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        z-index: 10;
        background: linear-gradient(to bottom, var(--bg-primary), transparent);
    }

    /* Close Button */
    .close-btn {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.2);
        color: #fca5a5;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 14px;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .close-btn:hover {
        background: rgba(239, 68, 68, 0.25);
        color: white;
        transform: rotate(90deg) scale(1.1);
        border-color: rgba(239, 68, 68, 0.4);
    }

    /* Content */
    .modal-content {
        position: relative;
        padding: 0 40px 40px;
        overflow-y: auto;
        z-index: 10;
    }

    /* Project Image */
    .project-preview-container {
        position: relative;
        width: 100%;
        height: 320px;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(239, 68, 68, 0.1);
    }

    .project-preview-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    }

    .project-preview-container:hover .project-preview-image {
        transform: scale(1.08);
    }

    .image-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to top,
            rgba(10, 1, 1, 0.6),
            transparent 60%
        );
        transition: opacity 0.5s ease;
    }

    .project-preview-container:hover .image-overlay {
        opacity: 0.8;
    }

    /* Buttons */
    .btn-modal-primary {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 24px;
        background: #ef4444;
        color: white;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(239, 68, 68, 0.3);
    }

    .btn-modal-primary:hover {
        background: #dc2626;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(239, 68, 68, 0.4);
    }

    .btn-modal-secondary {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 12px 24px;
        background: var(--glass-bg);
        color: var(--text-primary);
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        border: 1px solid var(--border-color);
        transition: all 0.3s ease;
    }

    .btn-modal-secondary:hover {
        background: rgba(255, 255, 255, 0.1);
        transform: translateY(-2px);
        border-color: rgba(239, 68, 68, 0.3);
    }

    /* Tech Badge */
    .tech-badge {
        padding: 6px 14px;
        background: var(--bg-accent);
        color: var(--text-muted);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        font-size: 0.8rem;
        font-weight: 500;
    }

    /* Scrollbar */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(239, 68, 68, 0.2);
        border-radius: 20px;
    }

    /* Mobile */
    @media (max-width: 640px) {
        .modal-header {
            padding: 25px 25px 15px;
        }
        .modal-content {
            padding: 0 25px 30px;
        }
        .project-preview-container {
            height: 220px;
        }
        .modal-container {
            max-height: 95vh;
            border-radius: 24px;
        }
    }
</style>

<script>
    // Universal functions for all project modals
    function openProjectModal(id: string) {
        const modal = document.getElementById(id);
        if (!modal) return;
        modal.classList.remove("hidden");
        modal.offsetHeight; // force reflow
        modal.classList.add("active");
        document.body.style.overflow = "hidden";
    }

    function closeProjectModal(id: string) {
        const modal = document.getElementById(id);
        if (!modal) return;
        modal.classList.remove("active");
        setTimeout(() => {
            modal.classList.add("hidden");
            document.body.style.overflow = "";
        }, 400);
    }

    // Event listener for close buttons
    document.querySelectorAll(".close-project-modal").forEach((btn) => {
        btn.addEventListener("click", () => {
            const id = btn.getAttribute("data-close-id");
            if (id) closeProjectModal(id);
        });
    });

    // Close on click outside
    document.querySelectorAll(".project-modal-backdrop").forEach((modal) => {
        modal.addEventListener("click", (e) => {
            if (e.target === modal) {
                closeProjectModal(modal.id);
            }
        });
    });

    // Close on escape
    window.addEventListener("keydown", (e) => {
        if (e.key === "Escape") {
            const activeModal = document.querySelector(
                ".project-modal-backdrop.active",
            );
            if (activeModal) closeProjectModal(activeModal.id);
        }
    });

    // Listen for custom trigger event from carousel
    window.addEventListener("trigger-project-modal", (e: any) => {
        if (e.detail && e.detail.id) {
            openProjectModal(`modal-project-${e.detail.id}`);
        }
    });
</script>
