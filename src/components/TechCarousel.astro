---
// TechCarousel component with infinite horizontal scroll
interface Tech {
  name: string;
  icon: string;
}

const technologies: Tech[] = [
  { name: "Laravel", icon: "devicon-laravel-original" },
  { name: "PHP", icon: "devicon-php-plain" },
  { name: "MySQL", icon: "devicon-mysql-plain" },
  { name: "Supabase", icon: "devicon-supabase-plain" },
  { name: "JavaScript", icon: "devicon-javascript-plain" },
  { name: "HTML", icon: "devicon-html5-plain" },
  { name: "CSS", icon: "devicon-css3-plain" },
  { name: "C", icon: "devicon-c-plain" },
  { name: "C#", icon: "devicon-csharp-plain" },
  { name: "Tailwind", icon: "devicon-tailwindcss-plain" },
  { name: "Bootstrap", icon: "devicon-bootstrap-plain" },
  { name: "WordPress", icon: "devicon-wordpress-plain" },
  { name: "jQuery", icon: "devicon-jquery-plain" },
  { name: "SQL Server", icon: "devicon-microsoftsqlserver-plain" },
  { name: "Astro", icon: "devicon-astro-plain" },
  { name: "Vue", icon: "devicon-vuejs-plain" },
];

// Duplicate array for seamless infinite scroll
const duplicatedTech = [...technologies, ...technologies];
---

<section class="relative w-full py-16 bg-[#050000] overflow-hidden">
  <div class="max-w-[1200px] mx-auto px-6">
    <!-- Section Title -->
    <h2
      class="text-xs font-semibold tracking-[0.2em] uppercase text-slate-400 text-center mb-12"
    >
      Trusted Technologies
    </h2>

    <!-- Carousel Container with Fade Masks -->
    <div class="relative">
      <!-- Left Fade Mask -->
      <div
        class="absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-[#050000] to-transparent z-10 pointer-events-none"
      >
      </div>

      <!-- Right Fade Mask -->
      <div
        class="absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-[#050000] to-transparent z-10 pointer-events-none"
      >
      </div>

      <!-- Infinite Carousel -->
      <div class="carousel-wrapper overflow-hidden">
        <div class="carousel-track flex gap-12 md:gap-8 py-4">
          <!-- First Set -->
          {
            duplicatedTech.map((tech) => (
              <div class="tech-item flex flex-col items-center justify-center gap-3 min-w-[120px] md:min-w-[100px] flex-shrink-0 group cursor-pointer">
                <div class="tech-icon w-20 h-20 md:w-14 md:h-14 py-4 flex items-center justify-center text-[#94a3b8] opacity-60 transition-all duration-300 group-hover:text-red-500 group-hover:opacity-100 group-hover:scale-110">
                  <span class="text-6xl font-bold">
                    <i class={tech.icon} />
                  </span>
                </div>
                <span class="tech-name text-sm md:text-xs font-medium text-[#94a3b8] opacity-80 transition-all duration-300 group-hover:text-red-500 group-hover:opacity-100 whitespace-nowrap">
                  {tech.name}
                </span>
              </div>
            ))
          }

          <!-- Second Set (for seamless loop) -->
          {
            duplicatedTech.map((tech) => (
              <div class="tech-item flex flex-col items-center justify-center gap-3 min-w-[120px] md:min-w-[100px] flex-shrink-0 group cursor-pointer">
                <div class="tech-icon w-16 h-16 md:w-14 md:h-14 py-4 flex items-center justify-center text-[#94a3b8] opacity-60 transition-all duration-300 group-hover:text-red-500 group-hover:opacity-100 group-hover:scale-110">
                  <span class="text-6xl font-bold">
                    <i class={tech.icon} />
                  </span>
                </div>
                <span class="tech-name text-sm md:text-xs font-medium text-[#94a3b8] opacity-80 transition-all duration-300 group-hover:text-red-500 group-hover:opacity-100 whitespace-nowrap">
                  {tech.name}
                </span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .carousel-wrapper {
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .carousel-track {
    animation: marquee 65s linear infinite;
    width: max-content;
    display: flex;
  }

  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Pause on hover for better UX */
  .carousel-wrapper:hover .carousel-track {
    animation-play-state: paused;
  }

  /* Responsive animation speed */
  @media (max-width: 768px) {
    .carousel-track {
      animation-duration: 30s;
    }
  }

  @media (max-width: 480px) {
    .carousel-track {
      animation-duration: 25s;
    }
  }
</style>
