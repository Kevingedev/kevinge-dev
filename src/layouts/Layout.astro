---
import Navbar from "../components/Navbar.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="es" data-theme="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content="Portfolio de Kevin Ruiz - Desarrollador Full Stack"
		/>
		<title>Kevin Ruiz - Portfolio</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
		<link
			rel="stylesheet"
			type="text/css"
			href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css"
		/>
	</head>
	<body>
		<Navbar />
		<slot />
	</body>
</html>

<style is:global>
	:root {
		/* Shared Colors */
		--color-primary: #ef4444;
		--color-primary-dark: #dc2626;
		--color-primary-glow: rgba(239, 68, 68, 0.4);

		/* Dark Theme (Default) */
		--bg-primary: #050000;
		--bg-secondary: #0a0101;
		--bg-accent: rgba(5, 0, 0, 0.8);
		--text-primary: #ffffff;
		--text-secondary: #94a3b8; /* slate-400 */
		--text-muted: #fca5a5;
		--border-color: rgba(239, 68, 68, 0.1);
		--card-bg: rgba(10, 1, 1, 0.95);
		--nav-bg: rgba(5, 0, 0, 0.2);
		--glass-bg: rgba(255, 255, 255, 0.03);
		--hero-glow: rgba(69, 10, 10, 0.4);
		--avatar-bg: linear-gradient(135deg, #1a0505 0%, #0a0000 100%);
	}

	html[data-theme="light"] {
		--bg-primary: #ffffff;
		--bg-secondary: #f8fafc;
		--bg-accent: rgba(255, 255, 255, 0.8);
		--text-primary: #0f172a;
		--text-secondary: #475569; /* slate-600 */
		--text-muted: #ef4444;
		--border-color: rgba(239, 68, 68, 0.15);
		--card-bg: rgba(255, 255, 255, 0.95);
		--nav-bg: rgba(255, 255, 255, 0.2);
		--glass-bg: rgba(15, 23, 42, 0.05);
		--hero-glow: rgba(239, 68, 68, 0.1);
		--avatar-bg: linear-gradient(135deg, #fee2e2 0%, #ffffff 100%);
	}

	html,
	body {
		margin: 0;
		padding: 0;
		width: 100%;
		overflow-x: hidden;
		min-height: 100vh;
		background-color: var(--bg-primary);
		color: var(--text-primary);
		font-family:
			"Inter",
			-apple-system,
			BlinkMacSystemFont,
			"Segoe UI",
			Roboto,
			Oxygen,
			Ubuntu,
			Cantarell,
			sans-serif;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		transition:
			background-color 0.3s ease,
			color 0.3s ease;
	}

	* {
		box-sizing: border-box;
	}
</style>
